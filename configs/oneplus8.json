{
  "name": "OnePlus 8 (instantnoodle)",
  "description": "OnePlus 8 - ColorOS 15 / Android 15",
  "KERNEL_SOURCE": "https://github.com/JackA1ltman/android_kernel_oneplus_sm8250_los_noksu.git",
  "KERNEL_BRANCH": "upstream-latest",
  "KERNEL_CONFIG": "vendor/kona-perf_defconfig",
  "KERNEL_IMAGE_NAME": "Image",
  "CLANG_SOURCE": "https://github.com/llvm/llvm-project/releases/download/llvmorg-20.1.0/LLVM-20.1.0-Linux-X64.tar.xz",
  "DEVICE_NAME": "oneplus_8",
  "DEVICE_CODENAME": "instantnoodle",
  "ENABLE_KERNELSU": true,
  "KERNELSU_BRANCH": "main",
  "KERNELSU_AUTO_FORK": "tiann",
  "ENABLE_SUSFS": true,
  "SUSFS_FIXED": true,
  "PACK_METHOD": "Anykernel3",
  "AK3_SOURCE": "https://github.com/osm0sis/AnyKernel3.git",
  "AK3_BRANCH": "master",
  "PACK_KMODULES": false,
  "REKERNEL_ENABLE": false,
  "DROIDSPACES_ENABLE": false,
  "HOOK_METHOD": "syscall",
  "KERNEL_PATCH": false,
  "BASEBAND_GUARD_ENABLE": true,
  "GENERATE_DTB": false,
  "GENERATE_CHIP": "qcom",
  "FREE_MORE_SPACE": false,
  "ROM_TEXT": "coloros15_a15",
  "CUSTOM_SCRIPTS": [
    {
      "url": "https://raw.githubusercontent.com/user/repo/main/custom-patch.sh",
      "description": "Custom patch script",
      "execute": true
    }
  ],
  "CUSTOM_COMMANDS": [
    {
      "command": "echo 'Preparing build environment'",
      "description": "Print build info",
      "working_directory": "kernel/source",
      "continue_on_error": false
    },
    {
      "command": "ls -la arch/arm64/boot/",
      "description": "List boot images",
      "working_directory": "kernel/source",
      "continue_on_error": false
    }
  ]
}
